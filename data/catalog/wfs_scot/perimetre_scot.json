      "type": "string"
    },
    "gpu_timestamp": {
      "type": "string"
    },
    "partition": {
      "type": "string"
    },
    "idurba": {
      "type": "string"
    },
    "the_geom": {
      "format": "geometry-geometry",
      "x-ogc-role": "primary-geometry",
      "x-ign-defaultCrs": "EPSG:4326"
    }
  },
  "required": []
}
