    "gpu_timestamp": {
      "type": "string"
    },
    "partition": {
      "type": "string"
    },
    "idgest": {
      "type": "string"
    },
    "nomgest": {
      "type": "string"
    },
    "nomcorres": {
      "type": "string"
    },
    "numtel": {
      "type": "string"
    },
    "courriel": {
      "type": "string"
    },
    "adresse": {
      "type": "string"
    },
    "the_geom": {
