{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "x-collection-id": "wfs_du:document",
  "type": "object",
  "title": "Document d'urbanisme",
  "description": "Emprise du document d'urbanisme, données issues du Géoportail de l'urbanisme",
  "properties": {
    "gid": {
      "type": "integer"
    },
    "id": {
      "type": "string"
    },
    "grid_name": {
      "type": "string"
    },
    "grid_title": {
      "type": "string"
    },
    "name": {
      "type": "string"
    },
    "gpu_doc_id": {
      "type": "string"
    },
    "gpu_status": {
      "type": "string"
    },
    "gpu_timestamp": {
      "type": "string"
    },
    "partition": {
      "type": "string"
    },
    "du_type": {
      "type": "string"
    },
    "the_geom": {
      "format": "geometry-geometry",
      "x-ogc-role": "primary-geometry",
      "x-ign-defaultCrs": "EPSG:4326"
    }
  },
  "required": []
}
