{
  "name": "@ignfab/gpf-schema-store",
  "description": "Experimental OGC API Features schema store enriched from Geoplateforme WFS.",
  "license": "MIT",
  "author": "IGNF",
  "version": "0.1.5",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "gpf-schema-store": "./dist/cli.js"
  },
  "files": [
    "dist",
    "data",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "dev": "vite-node src/cli.ts",
    "build": "vite build && tsc -p tsconfig.build.json",
    "start": "node dist/cli.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "vitest run --config vitest.config.all.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "preview": "npm run build && npm run start"
  },
  "dependencies": {
    "@camptocamp/ogc-client": "^1.3.0",
    "@fast-csv/format": "^5.0.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "minisearch": "^7.2.0",
    "undici": "^6.23.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/proxy-from-env": "^1.0.4",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "~6.0.2",
    "vite": "^8.0.8",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
