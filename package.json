{
  "name": "@ignfab/gpf-schema-store",
  "description": "Experimental OGC API Features schema store enriched from Geoplateforme WFS.",
  "license": "MIT",
  "author": "IGNF",
  "version": "0.2.0",
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "data",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "node --use-env-proxy ./node_modules/vite-node/dist/cli.mjs src/cli.ts",
    "cli": "node --use-env-proxy dist/cli.js",
    "update:all": "npm run update:namespaces && npm run update:source && npm run update:catalog",
    "update:source": "node --use-env-proxy dist/cli.js update",
    "update:namespaces": "node --use-env-proxy dist/cli.js update-namespaces",
    "update:catalog": "node --use-env-proxy dist/cli.js render-catalog data/catalog --clean",
    "check:overwrites": "node --use-env-proxy dist/cli.js check-overwrites",
    "start": "npm run cli",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:all": "vitest run --config vitest.config.all.ts",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "preview": "npm run build && npm run start"
  },
  "dependencies": {
    "@camptocamp/ogc-client": "^1.3.0",
    "@fast-csv/format": "^5.0.5",
    "commander": "^14.0.3",
    "js-yaml": "^4.1.1",
    "minisearch": "^7.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.4",
    "typescript": "~6.0.2",
    "unplugin-dts": "^1.0.3",
    "vite": "^8.0.8",
    "vite-node": "^6.0.0",
    "vitest": "^4.1.4"
  }
}
